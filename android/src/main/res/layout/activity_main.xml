<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ios_bg_dark"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar_main"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:navigationIconTint="@color/ios_blue"
            app:contentInsetStartWithNavigation="0dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Secure Scan"
                android:textColor="@color/white"
                android:textSize="34sp"
                android:fontFamily="sans-serif-condensed-medium"
                android:textStyle="bold" />
        </androidx.appcompat.widget.Toolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Scanning Status (Pulsing Icon) -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:gravity="center">
                
                <ImageView
                    android:id="@+id/status_icon"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_lock_idle_lock"
                    app:tint="@color/ios_blue"
                    android:background="@drawable/circle_bg_translucent"
                    android:padding="30dp" />
                
                <TextView
                    android:id="@+id/status_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:text="Ready to Scan"
                    android:textColor="@color/ios_label_secondary"
                    android:textSize="18sp"
                    android:layout_marginBottom="20dp" />
            </FrameLayout>

            <!-- Tag Information (Grouped List Style) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TAG INFORMATION"
                android:textColor="@color/ios_label_secondary"
                android:textSize="12sp"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/ios_surface_dark">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:divider="?android:attr/dividerVertical"
                    android:showDividers="middle">

                    <!-- UID Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Identifier"
                            android:textColor="@color/white" />
                        <TextView
                            android:id="@+id/uid_label"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="--"
                            android:textColor="@color/ios_label_secondary"
                            android:gravity="end" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="@color/ios_separator" android:layout_marginStart="16dp" />

                    <!-- Type Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="Technology"
                            android:textColor="@color/white" />
                        <TextView
                            android:id="@+id/type_label"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="--"
                            android:textColor="@color/ios_label_secondary"
                            android:gravity="end" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="@color/ios_separator" android:layout_marginStart="16dp" />

                    <!-- Content Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Payload Data"
                            android:textColor="@color/white"
                            android:layout_marginBottom="8dp" />
                        <TextView
                            android:id="@+id/content_label"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="No data detected"
                            android:textColor="@color/ios_label_secondary"
                            android:textSize="14sp"
                            android:background="@drawable/ios_inset_bg"
                            android:padding="12dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Log Console -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="SYSTEM LOGS"
                android:textColor="@color/ios_label_secondary"
                android:textSize="12sp"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="200dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/black">
                
                <ScrollView
                    android:id="@+id/log_scroll"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="12dp">
                    <TextView
                        android:id="@+id/log_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="> System initialized\n> Waiting for NFC event..."
                        android:textColor="@color/ios_green"
                        android:fontFamily="monospace"
                        android:textSize="11sp" />
                </ScrollView>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>